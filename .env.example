# Copy to .env (not committed) and fill for your machine.

# ComfyUI-scail install root (input/, output/, custom_nodes/)
# COMFYUI_SCAIL_ROOT=D:/ComfyUI-scail

# Or set folders explicitly:
# COMFYUI_INPUT=D:/ComfyUI-scail/input
# COMFYUI_OUTPUT=D:/ComfyUI-scail/output

# Kimodo package dir (…/custom_nodes/ComfyUI-Kimodo/kimodo)
# COMFYUI_KIMODO=

# MotionDiff custom node root
# COMFYUI_MOTIONDIFF=

# Python with torch for standalone Kimodo / matting (optional)
# COMFY_PYTHON=

# videoBGremoval repo root
# VIDEO_BG_REMOVAL_ROOT=D:/videoBGremoval

# Optional batch defaults
# STANDEE_DIR=D:/assets/standees
# MANNEQUIN_IMAGE=D:/assets/neutral_mannequin_front_9x16.png
