# Copy to .env (not committed) and fill for your machine.

# ComfyUI-scail install root (input/, output/, custom_nodes/)
# COMFYUI_SCAIL_ROOT=/path/to/ComfyUI-scail

# Or set folders explicitly:
# COMFYUI_INPUT=/path/to/ComfyUI-scail/input
# COMFYUI_OUTPUT=/path/to/ComfyUI-scail/output

# Kimodo package dir (…/custom_nodes/ComfyUI-Kimodo/kimodo)
# COMFYUI_KIMODO=

# MotionDiff custom node root
# COMFYUI_MOTIONDIFF=

# CUDA-enabled Python used for standalone Kimodo and native matting subprocesses.
# Install matching CUDA torch + torchvision first, then requirements-bgremove.txt.
# Example: COMFY_PYTHON=/path/to/python
# COMFY_PYTHON=

# Background removal backend.
# Default: native AniForge subprocess backend.
# Set to external only for legacy comparison with a sibling videoBGremoval repo.
# ANIFORGE_BGREMOVE_BACKEND=native
# VIDEO_BG_REMOVAL_ROOT=/path/to/videoBGremoval

# Optional local RMBG model directory. If unset, the native engine uses its bundled
# model directory when present or the Hugging Face cache/download path.
# RMBG_MODEL_DIR=

# Optional batch defaults
# STANDEE_DIR=/path/to/assets/standees
# MANNEQUIN_IMAGE=/path/to/assets/neutral_mannequin_front_9x16.png
